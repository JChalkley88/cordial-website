# Cordial Advisory website — server-side environment.
# Copy to .env.local and fill in. These never reach the browser.

# CRM inbound endpoint and shared secret (the contact form posts here)
CRM_INBOUND_URL=
CORDIAL_INBOUND_KEY=

# Marketing app subscribe endpoint and shared secret (newsletter opt-in)
MARKETING_TOOL_URL=
WEBSITE_SUBSCRIBE_SECRET=

# The website's OWN Resend key (separate from the CRM and marketing app keys),
# used only for the fallback emails so a lead or opt-in is never lost.
RESEND_API_KEY=
FALLBACK_EMAIL=jack@cordialadvisory.co.uk

# Google Analytics 4 Measurement ID (gtag.js). PUBLIC_ because it is sent to
# the browser; not a secret. Leave empty to disable analytics for a build.
PUBLIC_GA_MEASUREMENT_ID=


